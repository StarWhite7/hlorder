generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ENTREPRISE
}

enum DeliveryMode {
  WITH_DELIVERY
  WITHOUT_DELIVERY
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REFUSED
  PREPARING
  READY
  PICKED_UP
}

enum OrderItemType {
  PRODUCT
  MENU
}

enum CatalogType {
  CLIENT
  ENTREPRISE
}

model UserAuth {
  id         Int         @id @default(autoincrement())
  role       Role
  password   String
  isActive   Boolean     @default(true)
  deletedAt  DateTime?
  client     Client?
  entreprise Entreprise?
  sessions   Session[]
  ordersPlaced Order[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([isActive])
  @@index([deletedAt])
}

model Client {
  id         Int      @id @default(autoincrement())
  pseudo     String   @unique
  nomInGame  String
  prenomInGame String
  userAuthId Int      @unique
  userAuth   UserAuth @relation(fields: [userAuthId], references: [id], onDelete: Cascade)
  isActive   Boolean  @default(true)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([deletedAt])
}

model Entreprise {
  id           Int      @id @default(autoincrement())
  nomEntreprise String   @unique
  logoUrl      String?
  themeColor   String   @default("#0f6fcb") @db.VarChar(7)
  description  String?  @db.VarChar(120)
  userAuthId   Int      @unique
  userAuth     UserAuth @relation(fields: [userAuthId], references: [id], onDelete: Cascade)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  products     Product[]
  menus        Menu[]
  ordersReceived Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([deletedAt])
}

model Product {
  id                 Int         @id @default(autoincrement())
  entrepriseId       Int
  entreprise         Entreprise  @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  catalogType        CatalogType @default(CLIENT)
  name               String
  imageUrl           String?
  priceWithDelivery  Decimal     @db.Decimal(10, 2)
  priceWithoutDelivery Decimal   @db.Decimal(10, 2)
  isActive           Boolean     @default(true)
  menuProducts       MenuProduct[]
  orderItems         OrderItem[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([entrepriseId])
  @@index([isActive])
  @@index([catalogType])
  @@index([catalogType, isActive])
}

model Menu {
  id                 Int         @id @default(autoincrement())
  entrepriseId       Int
  entreprise         Entreprise  @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  catalogType        CatalogType @default(CLIENT)
  name               String
  imageUrl           String?
  priceWithDelivery  Decimal     @db.Decimal(10, 2)
  priceWithoutDelivery Decimal   @db.Decimal(10, 2)
  isActive           Boolean     @default(true)
  products           MenuProduct[]
  orderItems         OrderItem[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([entrepriseId])
  @@index([isActive])
  @@index([catalogType])
  @@index([catalogType, isActive])
}

model MenuProduct {
  menuId     Int
  productId  Int
  quantity   Int      @default(1)
  menu       Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([menuId, productId])
}

model Order {
  id                Int          @id @default(autoincrement())
  buyerUserAuthId   Int
  sellerEntrepriseId Int
  buyerUserAuth     UserAuth     @relation(fields: [buyerUserAuthId], references: [id], onDelete: Cascade)
  sellerEntreprise  Entreprise   @relation(fields: [sellerEntrepriseId], references: [id], onDelete: Cascade)
  status            OrderStatus  @default(PENDING)
  deliveryMode      DeliveryMode
  receptionDate     DateTime
  buyerNote         String?
  sellerNote        String?
  items             OrderItem[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([buyerUserAuthId])
  @@index([sellerEntrepriseId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          Int           @id @default(autoincrement())
  orderId     Int
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType    OrderItemType
  productId   Int?
  menuId      Int?
  product     Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  menu        Menu?         @relation(fields: [menuId], references: [id], onDelete: SetNull)
  itemName    String
  quantity    Int
  unitPrice   Decimal       @db.Decimal(10, 2)
  totalPrice  Decimal       @db.Decimal(10, 2)
  createdAt   DateTime      @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([menuId])
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userAuthId Int
  userAuth  UserAuth @relation(fields: [userAuthId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userAuthId])
  @@index([expiresAt])
}

model AuthThrottle {
  key         String   @id
  attempts    Int      @default(0)
  windowStart DateTime @default(now())
  blockedUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([blockedUntil])
}
